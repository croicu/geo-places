{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "geo-build (Edit)",
      "type": "debugpy",
      "request": "launch",
      "module": "geo_builder.cli",
      "python": "${workspaceFolder}/../geo-builder/.venv/Scripts/python.exe",
      "args": [
        "${workspaceFolder}/template.json",
        "--in", "${workspaceFolder}/public",
        "--out", "${workspaceFolder}/out",
        "--edit"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "geo-build (Overpass)",
      "type": "debugpy",
      "request": "launch",
      "module": "geo_builder.cli",
      "python": "${workspaceFolder}/../geo-builder/.venv/Scripts/python.exe",
      "args": [
        "${workspaceFolder}/template.json",
        "--in", "${workspaceFolder}/public",
        "--out", "${workspaceFolder}/out"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "geo-build (Test)",
      "type": "debugpy",
      "request": "launch",
      "module": "geo_builder.cli",
      "python": "${workspaceFolder}/../geo-builder/.venv/Scripts/python.exe",
      "args": [
        "${workspaceFolder}/template.json",
        "--in", "${workspaceFolder}/tests/data",
        "--out", "${workspaceFolder}/out"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
