{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: dev",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": ".*Local:.*"
        }
      }
    },
    {
      "label": "build: geo-places",
      "type": "shell",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "windows": {
        "command": "${workspaceFolder}\\build.cmd"
      },
      "linux": {
        "command": "bash ${workspaceFolder}/build.sh"
      },
      "osx": {
        "command": "bash ${workspaceFolder}/build.sh"
      }
    },
    {
      "label": "clean: public/ (strip designer-pulled data)",
      "type": "shell",
      "command": "python ${workspaceFolder}/scripts/clean_public.py",
      "problemMatcher": []
    }
  ]
}
